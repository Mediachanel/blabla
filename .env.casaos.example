APP_PORT=3000
MYSQL_PORT=3306
MYSQL_CONNECT_TIMEOUT_MS=1500

JWT_SECRET=
APP_ORIGIN=http://alamat-server-anda:3000

# Mengikuti pola db_config.php project PHP lama:
# coba nama service MariaDB, host Docker, gateway Docker, IP host CasaOS, lalu localhost container.
MYSQL_HOST=mariadb
MYSQL_HOSTS=mariadb,host.docker.internal,172.17.0.1,172.31.254.56,127.0.0.1

# Screenshot phpMyAdmin menunjukkan database aktif bernama si_data.
# sisdmk2 tetap dicoba sebagai fallback karena project PHP lama memakai nama itu.
MYSQL_DATABASE=si_data
MYSQL_DATABASES=si_data,sisdmk2

# Samakan dengan kredensial yang berhasil login di phpMyAdmin.
MYSQL_USER=root
MYSQL_PASSWORD=

# Kalau memakai MySQL bawaan docker-compose ini, pakai:
# MYSQL_HOST=db
# MYSQL_DATABASE=sisdmk2
# MYSQL_USER=sisdmk2_user
# MYSQL_PASSWORD=ganti-user-password
