APP_PORT=3000
MYSQL_PORT=3306

JWT_SECRET=ganti-dengan-secret-yang-panjang-dan-acak
MYSQL_ROOT_PASSWORD=ganti-root-password

# Pakai database MySQL yang sudah terlihat di phpMyAdmin/CasaOS.
# Dari container CasaOS, host phpMyAdmin pada screenshot terbaca sebagai host.docker.internal:3306.
MYSQL_HOST=host.docker.internal
MYSQL_DATABASE=si_data
MYSQL_USER=root
MYSQL_PASSWORD=

# Kalau memakai MySQL bawaan docker-compose ini, pakai:
# MYSQL_HOST=db
# MYSQL_DATABASE=sisdmk2
# MYSQL_USER=sisdmk2_user
# MYSQL_PASSWORD=ganti-user-password
